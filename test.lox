fun fib(n) {
  if (n <= 1) return n;
  return fib(n - 2) + fib(n - 1);
}

print(fib(10));


var arr = [1, 2, 3];

fun bubbleSort(arr) {
  var n = arr.length;
  for (var i = 0; i < n; i = i + 1) {
    for (var j = 0; j < n - i - 1; j = j + 1) {
      if (arr[j] > arr[j + 1]) {
        var temp = arr[j];
        arr[j] = arr[j + 1];
        arr[j + 1] = temp;
      }
    }
  }

  return arr;
}


print(bubbleSort(arr));
